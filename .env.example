# ============================================================
#  DE GUSTA PIZZAS — VARIÁVEIS DE AMBIENTE
#  Copie este arquivo para .env e preencha os valores
#  cp .env.example .env
# ============================================================

# ---- SERVIDOR ----
PORT=3000
NODE_ENV=production

# ---- ASAAS (Pagamentos PIX/Cartão) ----
# Obtenha em: https://www.asaas.com → Integrações → Chave API
ASAAS_API_KEY=seu_asaas_api_key_aqui

# ---- WHATSAPP ----
# Número com DDI+DDD sem espaços ou traços (ex: 5511934195908)
WHATSAPP_PHONE=5511934195908

# ---- GOOGLE MAPS (Componente de Mapa) ----
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
# Ative: Maps JavaScript API, Places API, Geocoding API
VITE_FRONTEND_FORGE_API_KEY=sua_google_maps_api_key_aqui

# ---- OAUTH (se utilizar login social) ----
# Deixe em branco se não usar autenticação OAuth
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
